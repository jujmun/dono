# Convex environment variables
# Run `npx convex dev` to create and populate .env.local automatically.
# Set AUTH_* on the Convex deployment with `npx convex env set ...`
# (convex/ process.env reads deployment env, not only this file).

CONVEX_DEPLOYMENT=
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=

# Auth email delivery (Resend + Oslo OTP)
AUTH_RESEND_KEY=
# Must use an address on a domain verified in your Resend account.
AUTH_EMAIL_FROM="Dono <auth@your-verified-domain.com>"
# Sign-in is restricted to Oxford emails (ox.ac.uk and subdomains) in code;
# see convex/auth/ResendEmailOTP.ts. The outreach admin address below is also
# allowed client-side and uses the admin-email OTP provider.

# Outreach admin portal (not the local ox.ac.uk OTP bypass).
# Client hardcodes dono.outreach@gmail.com as the sole non-Oxford login exception
# (lib/auth/admin.ts). Set matching values on the Convex deployment:
#   npx convex env set ADMIN_EMAIL dono.outreach@gmail.com
#   npx convex env set ADMIN_CODE_RECIPIENT dono.outreach@gmail.com
# Additional admins (e.g. juyeon27312@gmail.com) are hardcoded in
# lib/auth/admin.ts and convex/auth/adminConfig.ts.
# TEMPORARY LOCAL DEV ONLY — never enable on shared/production deployments.
# Server ignores AUTH_ADMIN_OTP_BYPASS on Convex prod: deployments.
# Client auto-bypass also requires __DEV__ + EXPO_PUBLIC_AUTH_ADMIN_OTP_BYPASS=true.
# When enabled, admin@ox.ac.uk uses fixed OTP 000000 (no email); others get random OTPs.
# This bypass is separate from the /admin portal (dono.outreach@gmail.com).
AUTH_ADMIN_OTP_BYPASS=
EXPO_PUBLIC_AUTH_ADMIN_OTP_BYPASS=

# PostHog (filled by PostHog wizard or manually)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Stripe payments
# Set STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET on the Convex deployment:
#   npx convex env set STRIPE_SECRET_KEY sk_test_...
#   npx convex env set STRIPE_WEBHOOK_SECRET whsec_...
# Client publishable key: set in .env.local for local, and in Vercel Project
# Settings → Environment Variables for production/preview (EXPO_PUBLIC_* only).
# Stripe webhooks go to Convex (*.convex.site/stripe/webhook), not Vercel.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
