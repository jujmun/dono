# Convex environment variables
# Run `npx convex dev` to create and populate .env.local automatically.

CONVEX_DEPLOYMENT=
EXPO_PUBLIC_CONVEX_URL= https://brave-parakeet-947.eu-west-1.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=

# Auth email delivery (Resend + Oslo OTP)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="Dono <auth@dono.app>"
# Sign-in is restricted to Oxford emails (ox.ac.uk and subdomains) in code;
# see convex/auth/ResendEmailOTP.ts.

# Dev-only test-mode sign-in bypass (NOT a client var — set via
# `npx convex env set TEST_MODE_EMAIL "test@dono.dev"` on your LOCAL Convex
# deployment only). NEVER set this on a preview or production deployment:
# it exempts exactly that one address from the Oxford-domain check and logs
# its OTP to the Convex function logs instead of emailing it.
# TEST_MODE_EMAIL=

# PostHog (filled by PostHog wizard or manually)
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
